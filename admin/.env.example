# =============================================================================
# admin/.env.example
#
# Required at runtime by admin/server.js for the /api/* endpoints that read
# from the SMS Supabase. Copy to .env.local for local dev (the root .gitignore
# already excludes .env.local). On Hostinger, set these via the control panel's
# Node.js → Environment Variables section.
# =============================================================================

# Port for the Node server. Hostinger injects its own PORT; leave commented in prod.
# PORT=3000

# ── Supabase (SMS database) ──────────────────────────────────────────────────
# URL: Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Service-role key — server-only secret, never leaves admin/server.js.
# Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Firebase Admin (used to verify the Authorization: Bearer ID token) ──────
# Three ways to provide the service account JSON, in order of preference:
#
# 1) BASE64-encoded JSON (recommended for Hostinger control panel — avoids
#    the newline-in-private_key gotcha that breaks plain-JSON paste-in).
#    Encode on macOS / Linux with:
#       base64 -i ~/.config/rka-academic-tracker/service-account.json
#    (or `cat … | base64` on Linux). Paste the single-line result.
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNj...
#
# 2) Raw JSON string (only safe if your host preserves \n inside the value).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"rka-academic-tracker",...}
#
# 3) Filesystem path (best for local dev). For this project the file
#    already exists at the path below from earlier backfill work:
FIREBASE_SERVICE_ACCOUNT_PATH=/Users/adwitsdocs/.config/rka-academic-tracker/service-account.json
