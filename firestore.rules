rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // token.email is ABSENT on phone-only admin sessions (custom-token
    // sign-in, verify-otp). Dereferencing a missing key errors — it does
    // not return false — so every email access goes through this guard.
    function tokenEmail() {
      return request.auth.token.get('email', '');
    }
    function isSuperAdmin() {
      return request.auth != null && tokenEmail().lower() == 'adwit@rkacademyballia.in';
    }
    function isAdmin() {
      return request.auth != null && (
        isSuperAdmin() ||
        // Phone-only admins: their Firebase UID is their admins docId.
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (tokenEmail() != '' &&
         exists(/databases/$(database)/documents/admins/$(tokenEmail().lower())))
      );
    }
    function isSchoolUser() {
      return isAdmin();
    }
    function isAnyTeacher() {
      return request.auth != null;
    }
    function getMyClassAssignment() {
      return get(/databases/$(database)/documents/classTeacherByEmail/$(request.auth.token.email.lower())).data;
    }
    function isMyClassStudent(className, branchCode) {
      return request.auth != null
        && exists(/databases/$(database)/documents/classTeacherByEmail/$(request.auth.token.email.lower()))
        && getMyClassAssignment().className == className
        && getMyClassAssignment().branchCode == branchCode;
    }
    function diffsOnlyAcademicFields() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly([
        'subjectsTaught',
        'classesAssigned',
        'qualification',
        'joiningDate',
        'updatedAt',
        'classTeacherOf',
      ]);
    }
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    match /teachers/{id} {
      allow read: if request.auth != null;
      allow create: if false;
      allow delete: if false;
      allow update: if isSchoolUser() && diffsOnlyAcademicFields();
    }
    match /classTeacherByEmail/{email} {
      allow read: if request.auth != null;
      allow write: if isSchoolUser();
    }
    match /settings/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /classes/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /syllabus/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /syllabusDocuments/{id} {
      allow read, write: if isSchoolUser();
    }
    match /lessons/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /lessonPlans/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /tests/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /testMarks/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /students/{id} {
      // SMS is the SINGLE SOURCE OF TRUTH for student data. The legacy
      // Firestore copy is read-only for every client — no app may create,
      // edit or delete students here. Server-side sync (Admin SDK)
      // bypasses rules by design.
      allow read: if isAnyTeacher();
      allow create, update, delete: if false;
    }
    match /studentAudit/{id} {
      allow read: if isAnyTeacher();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Student attendance: deterministic doc ID = '{date}_{studentId}'.
    //   read:    any authenticated user
    //   create/update/delete: admins anywhere, OR class teacher of that class+branch
    //   Edit window (7 days) is enforced in the UI, not in rules. Admin always.
    match /studentAttendance/{id} {
      allow read: if isAnyTeacher();
      allow create: if isSchoolUser()
        || isMyClassStudent(request.resource.data.className, request.resource.data.branchCode);
      allow update: if isSchoolUser()
        || isMyClassStudent(resource.data.className, resource.data.branchCode);
      allow delete: if isSchoolUser()
        || isMyClassStudent(resource.data.className, resource.data.branchCode);
    }
    // Attendance audit: append-only.
    match /attendanceAudit/{id} {
      allow read: if isAnyTeacher();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    match /timetable/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /arrangements/{id} {
      allow read: if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /studentProfiles/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /missedLessonAlerts/{id} {
      allow read, write: if isSchoolUser();
    }
    match /studentAlerts/{id} {
      allow read, write: if isSchoolUser();
    }

    // ── Report-card configuration (admin-owned) ─────────────────────────────
    // Sessions, terms, and the subject catalogue: admins create/edit; any
    // signed-in teacher reads (the teacher PWA needs them to discover
    // assigned subjects + current terms).
    match /examSessions/{id} {
      allow read:  if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /examTerms/{id} {
      allow read:  if isAnyTeacher();
      allow write: if isSchoolUser();
    }
    match /examSubjects/{id} {
      allow read:  if isAnyTeacher();
      allow write: if isSchoolUser();
    }

    // ── Report-card data entry (teacher-owned) ──────────────────────────────
    // Paper metadata, marks, co-scholastic grades, and HPC assessments are
    // written by teachers from the PWA. Same trust model as lessons/testMarks.
    match /examPapers/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /examMarks/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /examCoschGrades/{id} {
      allow read, write: if isAnyTeacher();
    }
    match /hpcAssessments/{id} {
      allow read, write: if isAnyTeacher();
    }
  }
}
