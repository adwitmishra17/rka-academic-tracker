# ─── Dependencies ────────────────────────────────────────────
node_modules/

# ─── Build output ────────────────────────────────────────────
dist/
build/
.vite/
build/Release

# ─── Env files (per-app and at root) ─────────────────────────
.env
.env.local
.env.development
.env.production
.env.*.local
!*.env.example
# Teacher PWA's .env.production holds only the public Supabase
# Functions URL (no secret) and is required at Vite build time
# so Hostinger's Node.js deploy can resolve it. Tracked deliberately.
!teacher/.env.production

# ─── Firebase ────────────────────────────────────────────────
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
.dataconnect/

# ─── Secrets — service account keys must NEVER hit git ───────
# (defense in depth — the actual file lives at
#  ~/.config/rka-academic-tracker/service-account.json, not here)
*adminsdk*.json
*service-account*.json
*-firebase-adminsdk-*.json
serviceAccount*.json
service-account*.json
*.pem
*.key

# ─── Archive / backup zips (older app versions) ──────────────
*.zip
RKA_Admin-v1*/
RKA_Teacher-v*/

# ─── Editor / OS ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Logs ────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Misc ────────────────────────────────────────────────────
.npm
.eslintcache
.parcel-cache
coverage/
.nyc_output/
.grunt
*.tgz
.yarn-integrity
.node_repl_history
pids
*.pid
*.seed
*.pid.lock
bower_components
.lock-wscript
lib-cov
